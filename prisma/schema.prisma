// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                    String                   @id @default(uuid())
  email                 String                   @unique
  passwordHash          String?
  name                  String
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  apiKeys               ApiKey[]
  routingPolicy         UploadRoutingPolicy?
  sessions              UserSession[]
  handoffs              AuthHandoff[]
  providerConfigs       ProviderConfig[]
  connectedAccounts     ConnectedAccount[]
  s3Configs             S3StorageConfig[]
  localConfigs          LocalStorageConfig[]
  folders               Folder[]
  files                 File[]
  shares                FileShare[]
  previewTokens         FilePreviewToken[]
  uploadSessions        UploadSession[]
  auditLogs             AuditLog[]
  invitesSent           WorkspaceInvite[]        @relation("Inviter")
  autoTieringRules      AutoTieringRule[]
  messengerIntegrations MessengerIntegration[]
  backupSchedules       DatabaseBackupSchedule[]
  cctvCameras           CctvCamera[]

  @@map("users")
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  name       String
  keyPrefix  String    @map("key_prefix")
  keyHash    String    @unique @map("key_hash")
  scopes     String    // Stored as JSON string in SQLite
  status     String    @default("active")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@map("api_keys")
}

model UploadRoutingPolicy {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  mode               String   @default("most_available")
  priorityAccountIds String   @map("priority_account_ids") // JSON string list
  roundRobinCursor   Int      @default(0) @map("round_robin_cursor")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("upload_routing_policies")
}

model UserSession {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([refreshTokenHash])
  @@map("user_sessions")
}

model AuthHandoff {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_handoffs")
}

model ProviderConfig {
  id                    String             @id @default(uuid())
  userId                String?            @map("user_id")
  provider              String
  clientIdEncrypted     String             @map("client_id_encrypted")
  clientSecretEncrypted String             @map("client_secret_encrypted")
  redirectUri           String             @map("redirect_uri")
  scopes                String             // JSON string scopes
  status                String             @default("active")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  connectedAccounts ConnectedAccount[]

  @@index([provider])
  @@map("provider_configs")
}

model ConnectedAccount {
  id                    String           @id @default(uuid())
  userId                String           @map("user_id")
  providerConfigId      String?          @map("provider_config_id")
  provider              String
  providerAccountId     String           @map("provider_account_id")
  email                 String
  displayName           String?          @map("display_name")
  avatarUrl             String?          @map("avatar_url")
  accessTokenEncrypted  String?          @map("access_token_encrypted")
  refreshTokenEncrypted String?          @map("refresh_token_encrypted")
  tokenExpiresAt        DateTime?        @map("token_expires_at")
  scopes                String           // JSON string scopes
  status                String           @default("connected")
  lastError             String?          @map("last_error")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerConfig ProviderConfig?  @relation(fields: [providerConfigId], references: [id], onDelete: SetNull)
  s3Config       S3StorageConfig?
  localConfig    LocalStorageConfig?
  storageAccount StorageAccount?
  folders        Folder[]
  files          File[]

  @@unique([userId, provider, providerAccountId])
  @@index([userId, status, createdAt])
  @@map("connected_accounts")
}

model S3StorageConfig {
  id                      String   @id @default(uuid())
  userId                  String   @map("user_id")
  connectedAccountId      String   @unique @map("connected_account_id")
  name                    String
  bucket                  String
  region                  String
  endpoint                String?
  accessKeyIdEncrypted    String   @map("access_key_id_encrypted")
  secretAccessKeyEncrypted String   @map("secret_access_key_encrypted")
  forcePathStyle          Boolean  @default(false) @map("force_path_style")
  prefix                  String   @default("clospol")
  quotaBytes              BigInt?  @map("quota_bytes")
  status                  String   @default("active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("s3_storage_configs")
}

model LocalStorageConfig {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  connectedAccountId String   @unique @map("connected_account_id")
  name               String
  serverPath         String   @map("server_path")
  quotaBytes         BigInt?  @map("quota_bytes")
  status             String   @default("active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("local_storage_configs")
}

model StorageAccount {
  id                 String    @id @default(uuid())
  connectedAccountId String    @unique @map("connected_account_id")
  totalBytes         BigInt?   @map("total_bytes")
  usedBytes          BigInt    @default(0) @map("used_bytes")
  availableBytes     BigInt?   @map("available_bytes")
  trashBytes         BigInt?   @map("trash_bytes")
  lastSyncedAt       DateTime? @map("last_synced_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@map("storage_accounts")
}

model Folder {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  parentId           String?   @map("parent_id")
  connectedAccountId String?   @map("connected_account_id")
  provider           String    @default("google_drive")
  providerFolderId   String?   @map("provider_folder_id")
  name               String
  color              String    @default("text-blue-500")
  iconUrl            String?   @map("icon_url")
  isStarred          Boolean   @default(false) @map("is_starred")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent           Folder?           @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children         Folder[]          @relation("FolderHierarchy")
  connectedAccount ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)
  files            File[]

  @@index([userId, deletedAt, updatedAt])
  @@index([userId, deletedAt, parentId, updatedAt])
  @@map("folders")
}

model File {
  id                 String             @id @default(uuid())
  userId             String             @map("user_id")
  connectedAccountId String             @map("connected_account_id")
  folderId           String?            @map("folder_id")
  provider           String
  providerFileId     String             @map("provider_file_id")
  name               String
  mimeType           String             @map("mime_type")
  sizeBytes          BigInt             @map("size_bytes")
  checksum           String?
  status             String             @default("active")
  isStarred          Boolean            @default(false) @map("is_starred")
  deletedAt          DateTime?          @map("deleted_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  shares             FileShare[]
  previewTokens      FilePreviewToken[]

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  folder           Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([userId, status, folderId, createdAt])
  @@index([providerFileId])
  @@map("files")
}

model FileShare {
  id             String    @id @default(uuid())
  fileId         String    @map("file_id")
  userId         String    @map("user_id")
  token          String?   @unique
  tokenHash      String    @unique @map("token_hash")
  enabled        Boolean   @default(true)
  maxDownloads   Int?      @map("max_downloads")
  downloadCount  Int       @default(0) @map("download_count")
  expiresAt      DateTime? @map("expires_at")
  passwordHash   String?   @map("password_hash")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled, createdAt])
  @@index([fileId, userId, enabled, createdAt])
  @@map("file_shares")
}

model FilePreviewToken {
  id        String   @id @default(uuid())
  fileId    String   @map("file_id")
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("file_preview_tokens")
}

model UploadSession {
  id                        String    @id @default(uuid())
  userId                    String    @map("user_id")
  targetConnectedAccountId  String?   @map("target_connected_account_id")
  fileName                  String    @map("file_name")
  mimeType                  String    @map("mime_type")
  sizeBytes                 BigInt    @map("size_bytes")
  status                    String
  errorMessage              String?   @map("error_message")
  completedAt               DateTime? @map("completed_at")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("upload_sessions")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   String?  // Stored as JSON string in SQLite
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model WorkspaceInvite {
  id           String    @id @default(uuid())
  inviterId    String    @map("inviter_id")
  inviteeEmail String    @map("invitee_email")
  targetType   String    @default("file") @map("target_type")
  targetId     String    @map("target_id")
  role         String    @default("viewer")
  status       String    @default("pending")
  revokedAt    DateTime? @map("revoked_at")
  acceptedAt   DateTime? @map("accepted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  inviter User @relation("Inviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([inviterId, inviteeEmail, targetType, targetId])
  @@index([inviteeEmail])
  @@index([targetType, targetId])
  @@map("workspace_invites")
}

model AutoTieringRule {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  name            String
  sourceAccountId String    @map("source_account_id")
  targetAccountId String    @map("target_account_id")
  ruleConditions  String    // JSON string conditions
  ruleAction      String    @map("rule_action")
  status          String    @default("active")
  lastRunAt       DateTime? @map("last_run_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auto_tiering_rules")
}

model MessengerIntegration {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  provider          String
  integrationName   String   @map("integration_name")
  status            String
  isActive          Boolean  @default(true) @map("is_active")
  botTokenEncrypted String   @map("bot_token_encrypted")
  sessionId         String?  @map("session_id")
  lastError         String?  @map("last_error")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messenger_integrations")
}

model DatabaseBackupSchedule {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  name                 String    @default("Database Backup")
  driver               String    @default("sqlite")
  host                 String?   @default("localhost")
  port                 Int?      @default(0)
  database             String    @default("dev.db")
  username             String?   @default("")
  passwordEncrypted    String?   @map("password_encrypted")
  headersEncrypted     String?   @map("headers_encrypted")
  cronExpression       String    @default("0 0 * * *") @map("cron_expression")
  retentionDays        Int       @default(7) @map("retention_days")
  backupFrequency      String    @map("backup_frequency")
  destinationProvider  String    @map("destination_provider")
  destinationAccountId String   @map("destination_account_id")
  lastBackupAt         DateTime? @map("last_backup_at")
  lastBackupStatus     String?   @map("last_backup_status")
  lastBackupError      String?   @map("last_backup_error")
  status               String    @default("active")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("database_backup_schedules")
}

model CctvCamera {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  connectedAccountId String?   @map("connected_account_id")
  name               String
  streamUrl          String    @map("stream_url")
  snapshotUrl        String?   @map("snapshot_url")
  snapshotHeaders    String?   @map("snapshot_headers") // JSON string headers
  recordStream       Boolean   @default(false) @map("record_stream")
  recordInterval     Int       @default(5) @map("record_interval")
  retentionDays      Int       @default(7) @map("retention_days")
  scheduleCron       String?   @map("schedule_cron")
  status             String    @default("active")
  lastCaptureAt      DateTime? @map("last_capture_at")
  lastCaptureStatus  String?   @map("last_capture_status")
  lastCaptureError   String?   @map("last_capture_error")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cctv_cameras")
}
