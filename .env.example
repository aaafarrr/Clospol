# Clospol Storage Gateway Environment Configurations

# Base Application Setup
PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_KEY="" # Generate a 32-byte hex string (e.g. openssl rand -hex 32)
JWT_ACCESS_SECRET="" # Generate a secure JWT signing secret
TZ="Asia/Jakarta"
GITHUB_REPO="aaafarrr/Clospol"

# Database Configuration
DATABASE_URL="file:./dev.db"

# Storage Boundaries
MAX_UPLOAD_BYTES=5368709120 # 5 GB

# Google Drive Provider Configurations
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/oauth/google/callback"
GOOGLE_SCOPES="https://www.googleapis.com/auth/drive,https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/userinfo.profile"
GOOGLE_DRIVE_ROOT_FOLDER="clospol"

# OneDrive Provider Configurations
ONEDRIVE_CLIENT_ID=""
ONEDRIVE_CLIENT_SECRET=""
ONEDRIVE_REDIRECT_URI="http://localhost:3000/api/oauth/onedrive/callback"
ONEDRIVE_SCOPES="offline_access Files.ReadWrite User.Read"
ONEDRIVE_PREFIX="clospol"

# Dropbox Provider Configurations
DROPBOX_CLIENT_ID=""
DROPBOX_CLIENT_SECRET=""
DROPBOX_REDIRECT_URI="http://localhost:3000/api/oauth/dropbox/callback"
DROPBOX_SCOPES="files.metadata.read files.content.write files.content.read"
DROPBOX_PREFIX="clospol"

# Custom S3 Prefix Default
S3_PREFIX="clospol"

# Google reCAPTCHA Setup (Optional)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# Cloud Registry Configurations (Used for configuration synchronization backup/restore)
REGISTRY_STORAGE_ACCOUNT_ID=""
REGISTRY_AUTO_SYNC=true
REGISTRY_PASSPHRASE_ENC=""
